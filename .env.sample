# ============================
# LangGraph RAG Pipeline — Configuración
# ============================

# --- LLM (OpenAI-compatible) ---
# OPENAI_API_KEY=sk-...
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Dejar vacío para OpenAI, o usa http://localhost:11434/v1 para Ollama
OPENAI_BASE_URL=

# --- Embeddings ---
EMBEDDING_MODEL=intfloat/e5-small

# --- RAG ---
DOCS_PATH=data/docs
VECTORSTORE_PATH=vectorstore/faiss_index
RAG_TOP_K=4
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
# Modos: none (ReAct con tool), auto (pipeline RAG), both (pipeline + tool de refinamiento)
RAG_MODE=both
# Máximo de re-escrituras de query cuando los docs no son relevantes
MAX_REWRITES=2

# --- Memoria ---
# Opciones: memory (en RAM) o sqlite (persistente)
CHECKPOINTER=memory
CHECKPOINT_DB=data/checkpoints.sqlite

# --- Logging ---
LOG_LEVEL=INFO

# --- CLI ---
THREAD_ID=cli-session-1
